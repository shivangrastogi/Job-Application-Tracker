rules_version = '2';

// AppliTrack — shared by the web and mobile apps (same Firebase project).
// Every user can read/write ONLY their own data under users/{uid}/...
// The wildcard {document=**} covers every subcollection (applications,
// interviews, contacts, timeline, companies, goals, referral_sources,
// referrals, documents) — so you never have to edit this when adding a new
// collection. If you instead list collections one-by-one, a missing one (e.g.
// "referrals") gets its writes rejected and the data appears to vanish on
// refresh.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
